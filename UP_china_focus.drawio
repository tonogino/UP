<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net" modified="2026-07-08T08:39:37.412Z" agent="HOI4 Modding Tools" version="1.0">
  <diagram id="focus-tree" name="UP_china_focus">
    <mxGraphModel dx="1000" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1920" pageHeight="1080">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="2" value="&lt;b&gt;Victory of the Revolution&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Nanjing has proven that the old order can be defeated. Now the revolution must learn to govern China.&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;35 days | UP_CHI_victory_of_revolution&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="5650" y="50" width="180" height="110" as="geometry"/></mxCell><mxCell id="3" value="&lt;b&gt;Consolidate the Central Government&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;The revolutionary league must build taxation, railways, military administration, and cadres.&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;35 days | UP_CHI_consolidate_central_government&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="5650" y="180" width="180" height="110" as="geometry"/></mxCell><mxCell id="4" value="&lt;b&gt;The Revolution Is Not Finished&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Southwest China, South China, the Northwest, Xinjiang, Tibet, and Manchuria remain outside full central authority.&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;35 days | UP_CHI_revolution_still_unfinished&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="5650" y="310" width="180" height="110" as="geometry"/></mxCell><mxCell id="5" value="&lt;b&gt;Chinese Unification War&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Not every negotiation begins with war, but every negotiation must feel the weight of the Revolutionary Army.&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;35 days | UP_CHI_chinese_unification_war&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="5650" y="440" width="180" height="110" as="geometry"/></mxCell><mxCell id="6" value="&lt;b&gt;The Republic of China Question&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;The Chongqing remnant government remains entangled with regional forces. Nanjing will handle this political question separately.&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;21 days | UP_CHI_southwest_question&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="5650" y="700" width="180" height="110" as="geometry"/></mxCell><mxCell id="7" value="&lt;b&gt;渗透重庆行政系统&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;重庆仍保留着一套旧国民政府行政机器。南京将通过联络旧部、安插交通员和控制财政线索，先撬开这套机器的缝隙。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;21 days | UP_CHI_infiltrate_chongqing_bureaucracy&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="5650" y="830" width="180" height="110" as="geometry"/></mxCell><mxCell id="8" value="&lt;b&gt;压迫四川地方派系&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;四川地方派系是重庆赖以存在的后方。通过军事压力、交通封锁和政治许诺，南京将迫使他们重新考虑自己的立场。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;21 days | UP_CHI_pressure_sichuan_cliques&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="5650" y="960" width="180" height="110" as="geometry"/></mxCell><mxCell id="9" value="&lt;b&gt;The Remaining Warlords Question&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;South China, the Northwest, Xinjiang and Tibet still retain different forms of local autonomy. Nanjing will handle them through one shared unification process.&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;21 days | UP_CHI_remaining_warlords_question&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="6050" y="700" width="180" height="110" as="geometry"/></mxCell><mxCell id="10" value="&lt;b&gt;The Manchurian Question&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Manchuria requires political preparation before Nanjing can choose peace or force.&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;21 days | UP_CHI_manchurian_question_unification&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="5250" y="700" width="180" height="110" as="geometry"/></mxCell><mxCell id="11" value="&lt;b&gt;Northeast Revolutionary Committee&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Organize underground networks and cadres in the Northeast.&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;21 days | UP_CHI_northeast_revolutionary_committee&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="5250" y="830" width="180" height="110" as="geometry"/></mxCell><mxCell id="12" value="&lt;b&gt;Contact Anti-Japanese Guerrillas&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Guerrilla networks will become Nanjing&apos;s hand inside Manchuria.&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;21 days | UP_CHI_contact_anti_japanese_guerrillas&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="5250" y="960" width="180" height="110" as="geometry"/></mxCell><mxCell id="13" value="&lt;b&gt;Unify the Southwest&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;当重庆被控制、归顺或成为南京附庸后，西南问题就可以宣告解决。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_southwest_unification&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="5650" y="1220" width="180" height="110" as="geometry"/></mxCell><mxCell id="14" value="&lt;b&gt;Unify Others&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;华南、西北、新疆和西藏事务均已完成处理。南京可以把这些地方安排整合为统一秩序的一部分。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;0 days | UP_CHI_tibet_unification&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="6050" y="1220" width="180" height="110" as="geometry"/></mxCell><mxCell id="15" value="&lt;b&gt;Unify the Northeast&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;当沈阳与满洲政权被控制、归顺或附庸后，东北统一就可以完成。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;0 days | UP_CHI_northeast_unification&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="5250" y="1220" width="180" height="110" as="geometry"/></mxCell><mxCell id="16" value="&lt;b&gt;军事改革&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;革命军的扩张速度超过了参谋、训练和后勤体系的承受能力。南京需要先建立统一的军制框架。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;35 days | UP_CHI_military_reform&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="4250" y="700" width="180" height="110" as="geometry"/></mxCell><mxCell id="17" value="&lt;b&gt;地方军官&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;部分地方军官拥有实际带兵经验。中央可以吸收他们，但必须承担派系进入军队的风险。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;35 days | UP_CHI_local_officers&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="4050" y="830" width="180" height="110" as="geometry"/></mxCell><mxCell id="18" value="&lt;b&gt;地方部队&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;地方部队可以补充革命军兵员，也会增加整编和训练压力。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;35 days | UP_CHI_local_units&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="4450" y="830" width="180" height="110" as="geometry"/></mxCell><mxCell id="19" value="&lt;b&gt;骑兵连&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;在道路条件较差的地区，骑兵仍能承担侦察、巡逻和通信任务。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;35 days | UP_CHI_cavalry_company&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="3450" y="830" width="180" height="110" as="geometry"/></mxCell><mxCell id="20" value="&lt;b&gt;重组革命军&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;将地方部队、旧军官和革命军骨干编入统一序列，是建立现代军队的前提。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;35 days | UP_CHI_reorganize_revolutionary_army&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="4250" y="1090" width="180" height="110" as="geometry"/></mxCell><mxCell id="21" value="&lt;b&gt;恢复高考&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;南京将恢复统一考试制度，为军政机构和工程院校提供稳定的人才来源。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;35 days | UP_CHI_restore_gaokao&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="3250" y="1220" width="180" height="110" as="geometry"/></mxCell><mxCell id="22" value="&lt;b&gt;机动化与坦克方案&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;中国缺少成熟装甲工业，但可以先建立机动化和装甲研究方案。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;35 days | UP_CHI_motorization_tank_card&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="3650" y="1220" width="180" height="110" as="geometry"/></mxCell><mxCell id="23" value="&lt;b&gt;步兵装备方案&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;步兵装备仍是革命军的主要基础。标准化枪械和弹药规格可以降低长期维护成本。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;35 days | UP_CHI_infantry_equipment_card&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="4250" y="1220" width="180" height="110" as="geometry"/></mxCell><mxCell id="24" value="&lt;b&gt;支援装备方案&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;通信、工兵、医疗和炮兵观测设备将直接影响部队作战效率。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;35 days | UP_CHI_support_equipment_card&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="4850" y="1220" width="180" height="110" as="geometry"/></mxCell><mxCell id="25" value="&lt;b&gt;机动化与坦克&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;中央军委将推动卡车、装甲车辆和装甲战术的早期研究。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;35 days | UP_CHI_motorization_and_tanks&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="3650" y="1480" width="180" height="110" as="geometry"/></mxCell><mxCell id="26" value="&lt;b&gt;卡车与火车方案&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;铁路和公路运输决定部队能否跨省调动。南京需要把军需运输纳入统一规划。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;35 days | UP_CHI_truck_and_train_card&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="4850" y="1480" width="180" height="110" as="geometry"/></mxCell><mxCell id="27" value="&lt;b&gt;枪械方案&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;统一枪械标准可以提高军工厂效率，也能降低地方部队整编成本。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;35 days | UP_CHI_rifle_card&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="4050" y="1350" width="180" height="110" as="geometry"/></mxCell><mxCell id="28" value="&lt;b&gt;火炮方案&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;火炮生产和训练体系将逐步摆脱临时采购和缴获依赖。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;35 days | UP_CHI_artillery_card&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="4450" y="1350" width="180" height="110" as="geometry"/></mxCell><mxCell id="29" value="&lt;b&gt;恢复自主研发能力&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;缺少外部红色中心意味着中国必须重建自己的研究机构和技术官僚体系。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;35 days | UP_CHI_restore_independent_research&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="4250" y="1480" width="180" height="110" as="geometry"/></mxCell><mxCell id="30" value="&lt;b&gt;第一所大学&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;新的国家大学将承担工程、军工、行政和师资培养任务。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;35 days | UP_CHI_first_university&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="4250" y="1610" width="180" height="110" as="geometry"/></mxCell><mxCell id="31" value="&lt;b&gt;整合内部工业势力&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;南京控制区内存在国营厂、地方工坊、商团资本和旧政府资产。中央需要先完成登记和整合。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;35 days | UP_CHI_integrate_internal_industrial_forces&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="6850" y="700" width="180" height="110" as="geometry"/></mxCell><mxCell id="32" value="&lt;b&gt;生产资料国有化&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;将关键生产资料纳入国家管理可以提高计划能力，但会影响短期稳定。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;35 days | UP_CHI_nationalize_means_of_production&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="7050" y="830" width="180" height="110" as="geometry"/></mxCell><mxCell id="33" value="&lt;b&gt;地方军官人才&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;一部分地方军官可以转入军工、后勤和训练机构，弥补中央人才不足。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;35 days | UP_CHI_local_officer_talent&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="7850" y="830" width="180" height="110" as="geometry"/></mxCell><mxCell id="34" value="&lt;b&gt;军用工业&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;南京将优先恢复弹药、枪械和轻型军需生产。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;35 days | UP_CHI_military_industry&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="6650" y="830" width="180" height="110" as="geometry"/></mxCell><mxCell id="35" value="&lt;b&gt;民用工业&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;民用工业是财政和长期建设的基础，不能完全让位于军工。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;35 days | UP_CHI_civilian_industry&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="7450" y="830" width="180" height="110" as="geometry"/></mxCell><mxCell id="36" value="&lt;b&gt;小米加步枪&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;在工业能力不足的阶段，基层动员和简易装备仍是革命军扩张的重要来源。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;35 days | UP_CHI_millet_and_rifles&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="6450" y="960" width="180" height="110" as="geometry"/></mxCell><mxCell id="37" value="&lt;b&gt;南京军工厂&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;南京军工厂将成为中央直接控制的军需生产核心。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;35 days | UP_CHI_nanjing_arms_factory&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="6850" y="960" width="180" height="110" as="geometry"/></mxCell><mxCell id="38" value="&lt;b&gt;南京汽车厂&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;汽车厂可以为军需运输和民用交通提供基础产能。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;35 days | UP_CHI_nanjing_auto_factory&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="7250" y="960" width="180" height="110" as="geometry"/></mxCell><mxCell id="39" value="&lt;b&gt;修建基础设施&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;恢复道路、桥梁和仓储设施是统一市场和军队调动的前提。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;35 days | UP_CHI_repair_infrastructure&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="7650" y="960" width="180" height="110" as="geometry"/></mxCell><mxCell id="40" value="&lt;b&gt;造更多的军工&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;军工扩建将提高战争准备，但会挤占其他建设资源。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;35 days | UP_CHI_build_more_military_factories&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="6650" y="1090" width="180" height="110" as="geometry"/></mxCell><mxCell id="41" value="&lt;b&gt;共和国的民用企业家&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;部分企业家愿意接受南京秩序。中央可以利用他们恢复生产和商业流通。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;35 days | UP_CHI_republic_civilian_entrepreneurs&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="7450" y="1090" width="180" height="110" as="geometry"/></mxCell><mxCell id="42" value="&lt;b&gt;土地归国有&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;土地国有化将加强中央对基层资源的掌握，同时引发地方利益调整。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;35 days | UP_CHI_land_nationalization&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="6650" y="1220" width="180" height="110" as="geometry"/></mxCell><mxCell id="43" value="&lt;b&gt;激进的企业家&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;一部分企业家愿意押注军工和国家订单，但这种路线会提高社会摩擦。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;35 days | UP_CHI_radical_entrepreneurs&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="7250" y="1220" width="180" height="110" as="geometry"/></mxCell><mxCell id="44" value="&lt;b&gt;温和的企业家&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;温和企业家更关注民用生产和商业秩序，有助于稳定经济恢复。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;35 days | UP_CHI_moderate_entrepreneurs&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="7650" y="1220" width="180" height="110" as="geometry"/></mxCell><mxCell id="45" value="&lt;b&gt;实现初步的计划经济&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;南京将建立早期计划机构，用于协调工厂、交通、粮食和军需。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;35 days | UP_CHI_initial_planned_economy&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="7450" y="1350" width="180" height="110" as="geometry"/></mxCell><mxCell id="46" value="&lt;b&gt;发行粮票&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;粮票制度可以帮助中央管理城市供应，但也意味着消费受到更严格的行政限制。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;35 days | UP_CHI_issue_grain_coupons&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="7450" y="1480" width="180" height="110" as="geometry"/></mxCell><mxCell id="47" value="&lt;b&gt;解决温饱问题的共和国&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;粮食调配和基层登记逐步稳定后，南京能够缓解部分地区的基本供应压力。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;35 days | UP_CHI_republic_solving_food_problem&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="7450" y="1610" width="180" height="110" as="geometry"/></mxCell><mxCell id="48" value="&lt;b&gt;清剿地方土匪&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;地方治安问题会阻碍税收、交通和征兵。中央将以军警力量恢复秩序。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;35 days | UP_CHI_suppress_local_bandits&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="6450" y="1350" width="180" height="110" as="geometry"/></mxCell><mxCell id="49" value="&lt;b&gt;规划地方土匪&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;中央也可以登记、改编和安置部分地方武装，把治安问题转化为劳役或辅兵来源。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;35 days | UP_CHI_register_local_bandits&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="6850" y="1350" width="180" height="110" as="geometry"/></mxCell><mxCell id="50" value="&lt;b&gt;大力发展重工业&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;钢铁、机械和化工是长期军工与基础设施建设的核心。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;35 days | UP_CHI_develop_heavy_industry&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="6650" y="1480" width="180" height="110" as="geometry"/></mxCell><mxCell id="51" value="&lt;b&gt;枪杆下的政权&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;南京的统一仍依赖军队执行力。国家机器会围绕武装力量继续扩张。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;35 days | UP_CHI_power_from_the_gun&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="6650" y="1610" width="180" height="110" as="geometry"/></mxCell><mxCell id="52" value="&lt;b&gt;Deal with Localism&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;中国统一只是第一步。真正麻烦的是如何处理各地残留的地方政府、军队、财政和政治承诺。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;21 days | UP_CHI_deal_with_localism&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="5650" y="1870" width="180" height="110" as="geometry"/></mxCell><mxCell id="53" value="&lt;b&gt;Strengthen the Central Government&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;中央集权路线要求南京直接控制所有关键地块。地方权力将被纳入统一行政体系。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;14 days | UP_CHI_centralization_path&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="5250" y="2130" width="180" height="110" as="geometry"/></mxCell><mxCell id="54" value="&lt;b&gt;Send Central Commissioners&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;中央专员将进入新统一地区，监督财政、警务、宣传和干部任命。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;14 days | UP_CHI_send_central_commissioners&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="5250" y="2260" width="180" height="110" as="geometry"/></mxCell><mxCell id="55" value="&lt;b&gt;Restrict Local Armies&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;地方武装必须被整编、裁撤或纳入中央指挥。革命军不能容忍第二套军令。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;14 days | UP_CHI_restrict_local_armies&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="5250" y="2390" width="180" height="110" as="geometry"/></mxCell><mxCell id="56" value="&lt;b&gt;The State Above Localities&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;南京宣布国家权威高于地方利益。中国将以更紧密的中央政府面对未来。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;14 days | UP_CHI_state_above_localities&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="5250" y="2520" width="180" height="110" as="geometry"/></mxCell><mxCell id="57" value="&lt;b&gt;Permit Local Autonomy&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;地方自治路线承认统一中国不能只靠命令。附庸和地方政府将获得更大的缓冲空间。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;14 days | UP_CHI_local_autonomy_path&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="6050" y="2130" width="180" height="110" as="geometry"/></mxCell><mxCell id="58" value="&lt;b&gt;Preserve Local Governments&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;保留地方政府可以降低整合成本，也能让边疆地区更愿意接受南京名义上的最高权威。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;14 days | UP_CHI_preserve_local_governments&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="6050" y="2260" width="180" height="110" as="geometry"/></mxCell><mxCell id="59" value="&lt;b&gt;Compromise with Local Interests&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;地方税收、宗教、商贸和军队问题都需要妥协。南京会付出代价，但能换来稳定。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;14 days | UP_CHI_compromise_local_interests&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="6050" y="2390" width="180" height="110" as="geometry"/></mxCell><mxCell id="60" value="&lt;b&gt;Revolutionary United Front&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;统一战线将把中央政府、地方自治政权和附庸地区包装进同一个革命叙事。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;14 days | UP_CHI_revolutionary_united_front&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="6050" y="2520" width="180" height="110" as="geometry"/></mxCell><mxCell id="61" value="&lt;b&gt;Complete National Unification&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;重庆、广州、兰州、乌鲁木齐、拉萨和沈阳都已被控制，或已进入南京秩序。全国统一终于可以宣告完成。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;0 days | UP_CHI_complete_national_unification&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="5650" y="2780" width="180" height="110" as="geometry"/></mxCell><mxCell id="62" value="&lt;b&gt;First National Congress&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;统一后的中国必须决定自己的未来。毛泽东路线、周恩来务实路线与黄埔军官团都将在大会后争夺国家方向。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;35 days | UP_CHI_first_national_congress&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="5650" y="3040" width="180" height="110" as="geometry"/></mxCell><mxCell id="63" value="&lt;b&gt;继续坚持社会主义道路&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;第一次全国代表大会之后，中国仍将以社会主义为国家建设的基本方向。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_continue_socialist_path&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="3450" y="3430" width="180" height="110" as="geometry"/></mxCell><mxCell id="64" value="&lt;b&gt;毛泽东主席&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;毛泽东继续作为革命与国家路线的核心象征。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_chairman_mao&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="3250" y="3560" width="180" height="110" as="geometry"/></mxCell><mxCell id="65" value="&lt;b&gt;周恩来总理&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;周恩来将承担更多行政、外交和经济恢复责任。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_premier_zhou&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="3650" y="3560" width="180" height="110" as="geometry"/></mxCell><mxCell id="66" value="&lt;b&gt;深入乡村&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;革命必须继续深入乡村基层，巩固农民动员和地方组织。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_deepen_countryside&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="1250" y="3820" width="180" height="110" as="geometry"/></mxCell><mxCell id="67" value="&lt;b&gt;阶级斗争不能忘&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;国家必须警惕革命内部重新出现的旧势力和新特权。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_class_struggle_never_forgotten&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="2250" y="3690" width="180" height="110" as="geometry"/></mxCell><mxCell id="68" value="&lt;b&gt;边缘化周恩来&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;务实行政路线被视为削弱革命锐气的危险倾向，周恩来的影响将被系统性削弱。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_marginalize_zhou_enlai&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="2850" y="3950" width="180" height="110" as="geometry"/></mxCell><mxCell id="69" value="&lt;b&gt;恢复国民经济&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;战争和统一造成的经济断裂必须尽快修复。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_restore_national_economy&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="3450" y="3690" width="180" height="110" as="geometry"/></mxCell><mxCell id="70" value="&lt;b&gt;务实的革命系统&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;周恩来将以行政、外交和经济协调为核心，建立一套能让革命国家正常运转的务实系统。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_zhou_pragmatic_system&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="4850" y="3690" width="180" height="110" as="geometry"/></mxCell><mxCell id="71" value="&lt;b&gt;支援贫农&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;贫农仍然是革命政权最重要的基层支柱。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_support_poor_peasants&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="1250" y="3950" width="180" height="110" as="geometry"/></mxCell><mxCell id="72" value="&lt;b&gt;批判教条主义&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;照搬外来理论不能解决中国现实，路线斗争必须指向具体问题。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_criticize_dogmatism&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="1650" y="3950" width="180" height="110" as="geometry"/></mxCell><mxCell id="73" value="&lt;b&gt;公开批斗反对派&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;反对派将被推到公开政治审查之下。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_publicly_struggle_opposition&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="2050" y="3950" width="180" height="110" as="geometry"/></mxCell><mxCell id="74" value="&lt;b&gt;批判经验主义&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;旧经验不能成为阻挡继续革命的借口。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_criticize_empiricism&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="2450" y="3950" width="180" height="110" as="geometry"/></mxCell><mxCell id="75" value="&lt;b&gt;稳定革命成果&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;纠正错误路线并不意味着否定革命，而是让革命成果能够被制度保存。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_stabilize_revolutionary_gains&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="450" y="3820" width="180" height="110" as="geometry"/></mxCell><mxCell id="76" value="&lt;b&gt;保留技术官僚&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;技术人员和专业官僚可以为工业、交通和财政恢复提供必要能力。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_retain_technocrats&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="50" y="4080" width="180" height="110" as="geometry"/></mxCell><mxCell id="77" value="&lt;b&gt;团结老干部&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;有经验的干部仍是国家恢复秩序的重要力量。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_unite_veteran_cadres&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="450" y="4080" width="180" height="110" as="geometry"/></mxCell><mxCell id="78" value="&lt;b&gt;恢复国家行政&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;行政系统必须重新拥有稳定、清晰和可执行的权威。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_restore_state_administration&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="850" y="4080" width="180" height="110" as="geometry"/></mxCell><mxCell id="79" value="&lt;b&gt;土地改革再推进&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;土地改革仍需深入到尚未完成基层重组的地区。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_advance_land_reform_again&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="1250" y="4080" width="180" height="110" as="geometry"/></mxCell><mxCell id="80" value="&lt;b&gt;整顿人民军队&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;人民军队必须服从政治路线，同时保持基本战斗力。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_rectify_peoples_army&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="2050" y="4210" width="180" height="110" as="geometry"/></mxCell><mxCell id="81" value="&lt;b&gt;第一个五年计划&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;新国家将用第一个五年计划恢复工业、基建和财政秩序。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_first_five_year_plan_mao&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="3450" y="3820" width="180" height="110" as="geometry"/></mxCell><mxCell id="82" value="&lt;b&gt;城市供应体系&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;城市粮食、燃料和日用品供应必须纳入稳定体系。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_urban_supply_system&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="4050" y="4210" width="180" height="110" as="geometry"/></mxCell><mxCell id="83" value="&lt;b&gt;将领大洗牌&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;军队高级指挥层将接受政治审查和重新调整。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_reshuffle_generals&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="2850" y="4210" width="180" height="110" as="geometry"/></mxCell><mxCell id="84" value="&lt;b&gt;纠正错误路线&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;革命需要纠正扩大化、简单化和行政失序的倾向。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_correct_wrong_line&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="250" y="3690" width="180" height="110" as="geometry"/></mxCell><mxCell id="85" value="&lt;b&gt;正确处理人民内部矛盾&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;人民内部矛盾不能简单等同于敌我矛盾。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_correctly_handle_people_contradictions&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="450" y="4340" width="180" height="110" as="geometry"/></mxCell><mxCell id="86" value="&lt;b&gt;党内自我批评&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;党内整风应当保留自我纠错机制，而不是只剩清算。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_party_self_criticism&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="1650" y="4210" width="180" height="110" as="geometry"/></mxCell><mxCell id="87" value="&lt;b&gt;清算地方机会主义&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;地方派系借革命名义保存私利的现象必须被清除。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_liquidate_local_opportunism&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="2450" y="4210" width="180" height="110" as="geometry"/></mxCell><mxCell id="88" value="&lt;b&gt;国家计划委员会&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;国家计划委员会将统一协调工业、交通和资源分配。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_state_planning_commission&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="3450" y="4210" width="180" height="110" as="geometry"/></mxCell><mxCell id="89" value="&lt;b&gt;重工业发展&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;重工业是国家独立和军事现代化的基础。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_heavy_industry_development&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="3250" y="4340" width="180" height="110" as="geometry"/></mxCell><mxCell id="90" value="&lt;b&gt;平衡发展工业&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;工业建设必须兼顾军工、民生和长期技术能力。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_balanced_industrial_development&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="3650" y="4340" width="180" height="110" as="geometry"/></mxCell><mxCell id="91" value="&lt;b&gt;粮食统购统销&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;粮食流通体系将被中央统一组织。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_grain_purchase_and_sale&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="4050" y="4470" width="180" height="110" as="geometry"/></mxCell><mxCell id="92" value="&lt;b&gt;彻底清算资本主义走狗&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;国家将把阶级斗争推进到更尖锐的政治清算阶段。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_liquidate_capitalist_running_dogs&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="2050" y="4470" width="180" height="110" as="geometry"/></mxCell><mxCell id="93" value="&lt;b&gt;对小资实现精准打击&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;小资产阶级倾向将被纳入重点审查范围。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_precision_strike_petty_bourgeois&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="2850" y="4470" width="180" height="110" as="geometry"/></mxCell><mxCell id="94" value="&lt;b&gt;团结民主人士&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;革命政府可以继续吸纳民主人士参与建设。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_unite_democratic_figures&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="250" y="4470" width="180" height="110" as="geometry"/></mxCell><mxCell id="95" value="&lt;b&gt;团结新一代人才&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;新一代技术和行政人才将进入国家建设体系。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_unite_new_generation_talent&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="650" y="4470" width="180" height="110" as="geometry"/></mxCell><mxCell id="96" value="&lt;b&gt;民众督促党&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;群众监督将成为压迫官僚主义和路线偏差的政治工具。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_people_supervise_party&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="1250" y="4470" width="180" height="110" as="geometry"/></mxCell><mxCell id="97" value="&lt;b&gt;建设新型机械厂&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;机械工业将支撑装备制造和工业升级。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_new_machine_factories&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="3250" y="4600" width="180" height="110" as="geometry"/></mxCell><mxCell id="98" value="&lt;b&gt;民用工业恢复&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;民用工业恢复将改善城市供应和社会稳定。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_civilian_industry_recovery&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="3650" y="4600" width="180" height="110" as="geometry"/></mxCell><mxCell id="99" value="&lt;b&gt;人民生活保障&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;社会主义建设必须最终落实到人民生活。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_people_livelihood_guarantee&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="4050" y="4730" width="180" height="110" as="geometry"/></mxCell><mxCell id="100" value="&lt;b&gt;恢复市场供应&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;在国家计划之外，有限恢复供应链可以缓解城市和农村压力。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_restore_market_supply&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="450" y="4730" width="180" height="110" as="geometry"/></mxCell><mxCell id="101" value="&lt;b&gt;阶级斗争扩大化&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;阶级斗争将从路线争论扩大为全国政治运动。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_class_struggle_escalation&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="2050" y="4730" width="180" height="110" as="geometry"/></mxCell><mxCell id="102" value="&lt;b&gt;第二个五年计划&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;第二个五年计划将把国家建设带入更系统的工业化阶段。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_second_five_year_plan&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="3450" y="4730" width="180" height="110" as="geometry"/></mxCell><mxCell id="103" value="&lt;b&gt;大跃进&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;中国将用群众动员和政治意志强行推动生产跃升。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_great_leap_forward&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="2450" y="4860" width="180" height="110" as="geometry"/></mxCell><mxCell id="104" value="&lt;b&gt;文化革命的火种&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;革命火种将被投向学校、机关和基层组织。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_cultural_revolution_spark&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="1650" y="4860" width="180" height="110" as="geometry"/></mxCell><mxCell id="105" value="&lt;b&gt;大字报&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;大字报会把路线斗争推到墙面、街头和每一个单位。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_big_character_posters&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="2050" y="4860" width="180" height="110" as="geometry"/></mxCell><mxCell id="106" value="&lt;b&gt;全面现代化&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;国家建设将转向工业、教育、科研和民生的全面现代化。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_comprehensive_modernization&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="3650" y="4990" width="180" height="110" as="geometry"/></mxCell><mxCell id="107" value="&lt;b&gt;务实的革命系统&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;革命将通过更稳定的行政、市场供应和群众监督继续存在。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_pragmatic_revolutionary_system&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="1250" y="5120" width="180" height="110" as="geometry"/></mxCell><mxCell id="108" value="&lt;b&gt;自力更生&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;中国必须依靠自己的工业、人民和政治意志建设国家。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_self_reliance&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="2450" y="5120" width="180" height="110" as="geometry"/></mxCell><mxCell id="109" value="&lt;b&gt;彻底粉碎旧秩序&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;旧秩序不仅要被击败，还要被从思想和组织上清除。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_smash_old_order&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="1650" y="5120" width="180" height="110" as="geometry"/></mxCell><mxCell id="110" value="&lt;b&gt;炮打司令部&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;路线斗争将直接指向党内最高层的保守和官僚倾向。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_bombard_headquarters&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="2050" y="5120" width="180" height="110" as="geometry"/></mxCell><mxCell id="111" value="&lt;b&gt;中国新社会主义建设&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;一个更现代、更稳定、更有工业能力的社会主义中国正在成形。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_new_socialist_construction&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="3650" y="5380" width="180" height="110" as="geometry"/></mxCell><mxCell id="112" value="&lt;b&gt;人民万岁&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;革命必须回到人民生活和国家稳定。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_people_long_live&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="1250" y="5380" width="180" height="110" as="geometry"/></mxCell><mxCell id="113" value="&lt;b&gt;无产阶级继续革命&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;文化大革命将被纳入继续革命理论，并转化为新的国家政治遗产。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_proletarian_continuing_revolution&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="2050" y="5380" width="180" height="110" as="geometry"/></mxCell><mxCell id="114" value="&lt;b&gt;重用周恩来&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;周恩来将重新承担行政、外交和经济协调职责。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_reemploy_zhou_enlai&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="50" y="3820" width="180" height="110" as="geometry"/></mxCell><mxCell id="115" value="&lt;b&gt;重建国务院&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;国务院系统将重新成为国家日常治理的核心。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_rebuild_state_council&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="4850" y="3950" width="180" height="110" as="geometry"/></mxCell><mxCell id="116" value="&lt;b&gt;和平建设&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;国家需要一段不被路线斗争吞噬的和平建设时期。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_peaceful_construction&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="5450" y="3950" width="180" height="110" as="geometry"/></mxCell><mxCell id="117" value="&lt;b&gt;恢复行政系统&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;行政系统必须恢复流程、责任和执行力。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_restore_administrative_system&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="4450" y="4080" width="180" height="110" as="geometry"/></mxCell><mxCell id="118" value="&lt;b&gt;恢复外交渠道&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;中国将重新打开与外部世界沟通的正式渠道。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_restore_diplomatic_channels&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="4850" y="4080" width="180" height="110" as="geometry"/></mxCell><mxCell id="119" value="&lt;b&gt;引进技术型人才&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;技术人才将被重新放到国家建设的关键位置。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_introduce_technical_talent&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="5250" y="4080" width="180" height="110" as="geometry"/></mxCell><mxCell id="120" value="&lt;b&gt;稳定的社会主义制度&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;社会主义制度需要稳定的法律、行政和经济基础。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_stable_socialist_system&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="5450" y="4210" width="180" height="110" as="geometry"/></mxCell><mxCell id="121" value="&lt;b&gt;民主大中国&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;在统一国家内部，制度化参与和行政协商将成为治理工具。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_democratic_greater_china&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="4850" y="4340" width="180" height="110" as="geometry"/></mxCell><mxCell id="122" value="&lt;b&gt;建立现代司法体系&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;现代司法体系将为社会秩序和经济活动提供基本保障。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_modern_judicial_system&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="5450" y="4340" width="180" height="110" as="geometry"/></mxCell><mxCell id="123" value="&lt;b&gt;全面实现言论自由&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;有限而制度化的表达空间可以降低政治爆炸的风险。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_freedom_of_expression&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="4850" y="4600" width="180" height="110" as="geometry"/></mxCell><mxCell id="124" value="&lt;b&gt;引进外国科技公司&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;外国技术公司可以帮助中国加速产业升级。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_introduce_foreign_tech_companies&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="5450" y="4600" width="180" height="110" as="geometry"/></mxCell><mxCell id="125" value="&lt;b&gt;人人为我，我为人人&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;公共生活、国家建设和个人命运将被纳入共同体叙事。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_all_for_one_one_for_all&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="4850" y="4860" width="180" height="110" as="geometry"/></mxCell><mxCell id="126" value="&lt;b&gt;全面开展高等教育&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;高等教育扩张将为工业和科研提供人才。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_higher_education_expansion&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="5250" y="4730" width="180" height="110" as="geometry"/></mxCell><mxCell id="127" value="&lt;b&gt;全面提高文化教育&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;文化教育水平提升是现代国家长期稳定的基础。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_raise_cultural_education&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="5650" y="4730" width="180" height="110" as="geometry"/></mxCell><mxCell id="128" value="&lt;b&gt;新科技，新生活&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;技术进步将被直接转化为民生改善和生产效率。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_new_technology_new_life&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="5450" y="4990" width="180" height="110" as="geometry"/></mxCell><mxCell id="129" value="&lt;b&gt;天下为公&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;中国将以公共利益、技术现代化和社会主义建设作为新的国家承诺。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_world_commonwealth&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="4850" y="5380" width="180" height="110" as="geometry"/></mxCell><mxCell id="130" value="&lt;b&gt;毛泽东领袖生涯&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;毛泽东的政治生涯必须被制度化处理。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_mao_political_career&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="4250" y="3690" width="180" height="110" as="geometry"/></mxCell><mxCell id="131" value="&lt;b&gt;平稳落地&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;在没有文革阴影的情况下，毛泽东可以以革命领袖的身份平稳退出日常权力中心。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_mao_smooth_landing&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="4050" y="3820" width="180" height="110" as="geometry"/></mxCell><mxCell id="132" value="&lt;b&gt;功过分明&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;文化大革命之后，国家必须同时承认毛泽东的革命功绩和政治灾难的代价。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_mao_balanced_judgement&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="4450" y="3820" width="180" height="110" as="geometry"/></mxCell><mxCell id="133" value="&lt;b&gt;秘密重建黄埔军校&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;军国主义派认为分裂中国只能靠军队重新缝合。革命不能被乡村会议拖慢，必须建立纪律、参谋部和统一战争机器。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_militarist_bloc&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="7250" y="3430" width="180" height="110" as="geometry"/></mxCell><mxCell id="134" value="&lt;b&gt;军队高于党派&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;军国主义派宣布革命同盟不能再被地方委员会、派系争论和党务纠缠拖住。军队必须高于党派，国家必须服从统一命令。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_army_above_parties&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="7250" y="3560" width="180" height="110" as="geometry"/></mxCell><mxCell id="135" value="&lt;b&gt;成立国家军事委员会&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;国家军事委员会将取代松散的革命军会议，把作战计划、军官任免和全国动员纳入同一指挥体系。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_establish_national_military_council&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="7250" y="3690" width="180" height="110" as="geometry"/></mxCell><mxCell id="136" value="&lt;b&gt;国家复兴运动&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;革命不再只是阶级口号，也将成为民族复兴的工具。南京要把社会动员转化为国家主义热情。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_national_revival_movement&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="7250" y="5510" width="180" height="110" as="geometry"/></mxCell><mxCell id="137" value="&lt;b&gt;收复东北&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;满洲问题是中国统一的伤口。南京不会承认脱离中国的东北政权。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_recover_the_northeast&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="6650" y="6030" width="180" height="110" as="geometry"/></mxCell><mxCell id="138" value="&lt;b&gt;印度的问题&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;该国策代表南京政府在当前路线下推进新的政治、军事或外交安排。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_india_question&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="2450" y="830" width="180" height="110" as="geometry"/></mxCell><mxCell id="139" value="&lt;b&gt;支援红色印度&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_support_red_india&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="2050" y="960" width="180" height="110" as="geometry"/></mxCell><mxCell id="140" value="&lt;b&gt;支持黑色印度（需要重建黄埔军校）&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;该国策代表南京政府在当前路线下推进新的政治、军事或外交安排。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_support_black_india&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="2850" y="960" width="180" height="110" as="geometry"/></mxCell><mxCell id="141" value="&lt;b&gt;新五军&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;该国策代表南京政府在当前路线下推进新的政治、军事或外交安排。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_new_fifth_army&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="11250" y="4340" width="180" height="110" as="geometry"/></mxCell><mxCell id="142" value="&lt;b&gt;山地师&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;该国策代表南京政府在当前路线下推进新的政治、军事或外交安排。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_mountain_divisions&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="10450" y="4860" width="180" height="110" as="geometry"/></mxCell><mxCell id="143" value="&lt;b&gt;建立标准化陆军&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;该国策代表南京政府在当前路线下推进新的政治、军事或外交安排。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_standardized_army&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="11050" y="4210" width="180" height="110" as="geometry"/></mxCell><mxCell id="144" value="&lt;b&gt;中华的陆军军官&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;该国策代表南京政府在当前路线下推进新的政治、军事或外交安排。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_chinese_army_officers&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="10850" y="4470" width="180" height="110" as="geometry"/></mxCell><mxCell id="145" value="&lt;b&gt;策反彭德怀&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;该国策代表南京政府在当前路线下推进新的政治、军事或外交安排。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_turn_peng_dehuai&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="10450" y="3820" width="180" height="110" as="geometry"/></mxCell><mxCell id="146" value="&lt;b&gt;重组黄埔陆军学院&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;该国策代表南京政府在当前路线下推进新的政治、军事或外交安排。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_reorganize_whampoa_army_academy&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="10450" y="4080" width="180" height="110" as="geometry"/></mxCell><mxCell id="147" value="&lt;b&gt;指挥部重建&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;该国策代表南京政府在当前路线下推进新的政治、军事或外交安排。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_rebuild_command_headquarters&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="10450" y="4470" width="180" height="110" as="geometry"/></mxCell><mxCell id="148" value="&lt;b&gt;我们都是神枪手&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;该国策代表南京政府在当前路线下推进新的政治、军事或外交安排。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_all_sharpshooters&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="10650" y="4730" width="180" height="110" as="geometry"/></mxCell><mxCell id="149" value="&lt;b&gt;海军陆战队&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;该国策代表南京政府在当前路线下推进新的政治、军事或外交安排。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_marine_corps&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="10850" y="4860" width="180" height="110" as="geometry"/></mxCell><mxCell id="150" value="&lt;b&gt;整编土匪&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;该国策代表南京政府在当前路线下推进新的政治、军事或外交安排。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_integrate_bandits&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="9850" y="4210" width="180" height="110" as="geometry"/></mxCell><mxCell id="151" value="&lt;b&gt;中国坦克&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;该国策代表南京政府在当前路线下推进新的政治、军事或外交安排。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_chinese_tanks&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="10050" y="4470" width="180" height="110" as="geometry"/></mxCell><mxCell id="152" value="&lt;b&gt;自行火炮&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;该国策代表南京政府在当前路线下推进新的政治、军事或外交安排。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_self_propelled_artillery&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="10250" y="4730" width="180" height="110" as="geometry"/></mxCell><mxCell id="153" value="&lt;b&gt;秘密接触张国焘&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;该国策代表南京政府在当前路线下推进新的政治、军事或外交安排。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_secret_contact_zhang_guotao&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="8650" y="3820" width="180" height="110" as="geometry"/></mxCell><mxCell id="154" value="&lt;b&gt;敢死队&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;该国策代表南京政府在当前路线下推进新的政治、军事或外交安排。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_dare_to_die_corps&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="9650" y="4340" width="180" height="110" as="geometry"/></mxCell><mxCell id="155" value="&lt;b&gt;黄埔优秀毕业生聚会（林彪成为法西斯政治顾问）&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;黄埔毕业生重新进入南京的军政网络。林彪被推到台前，成为青年军官、空军建设派和强硬民族主义者都能暂时接受的人选。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_whampoa_graduates_gathering&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="8050" y="3690" width="180" height="110" as="geometry"/></mxCell><mxCell id="156" value="&lt;b&gt;老虎中的战斗机&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;空军学校将优先培养战斗机飞行员。夺取制空权比地面上的每一次胜利都更难，也更昂贵。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_fighters_among_tigers&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="9050" y="3950" width="180" height="110" as="geometry"/></mxCell><mxCell id="157" value="&lt;b&gt;天上的老虎&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;新的中国空军需要自己的神话。训练场、航校和维修厂将被纳入同一套现代化计划。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_tigers_in_the_sky&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="9250" y="3820" width="180" height="110" as="geometry"/></mxCell><mxCell id="158" value="&lt;b&gt;老虎中的支援机&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;中国的战场辽阔而破碎，支援机能把前线指挥官的命令变成更直接的火力。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_support_planes_among_tigers&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="9450" y="3950" width="180" height="110" as="geometry"/></mxCell><mxCell id="159" value="&lt;b&gt;黄埔空军学院&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;黄埔系不愿让空军成为独立山头。新的空军学院会把飞行员教育、政治审查和军官团忠诚绑定在一起。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_whampoa_air_force_academy&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="9250" y="4210" width="180" height="110" as="geometry"/></mxCell><mxCell id="160" value="&lt;b&gt;密谋刺杀毛泽东（解锁决议）&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;黄埔系将开始策划针对毛泽东的行动。完成后会解锁刺杀决议，初始成功率为50%。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_plot_to_assassinate_mao&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="6050" y="4080" width="180" height="110" as="geometry"/></mxCell><mxCell id="161" value="&lt;b&gt;重建蓝衣社&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;蓝衣社重新建立。它会提高刺杀成功率，但也会带来稳定度损失和政治极化。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_rebuild_blue_shirts&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="6850" y="4080" width="180" height="110" as="geometry"/></mxCell><mxCell id="162" value="&lt;b&gt;军统系统&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;军统系统将成为黄埔线的情报中枢。完成后若拥有相关功能会自动建立情报部门，并解锁戴笠顾问。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_juntong_system&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="7650" y="4080" width="180" height="110" as="geometry"/></mxCell><mxCell id="163" value="&lt;b&gt;直接武装夺权（直接开启内战）&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;放弃阴谋路线，直接动员黄埔军官和地方部队发动武装夺权。刺杀决议将立刻关闭。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_direct_armed_seizure&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="8250" y="4080" width="180" height="110" as="geometry"/></mxCell><mxCell id="164" value="&lt;b&gt;刺杀行动失败&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;刺杀失败后的路线国策。黄埔系必须在肃清和反扑中保住自己的网络。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_assassination_failed&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="5850" y="4340" width="180" height="110" as="geometry"/></mxCell><mxCell id="165" value="&lt;b&gt;刺杀行动圆满成功&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;刺杀成功后的路线国策。林彪将作为过渡领袖上台，但新秩序仍然不稳。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_assassination_success&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="6250" y="4340" width="180" height="110" as="geometry"/></mxCell><mxCell id="166" value="&lt;b&gt;扩大招募&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;蓝衣社将在青年军官、学校和城市社团中扩大招募。这能提高刺杀成功率，但会刺激社会紧张。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_expand_recruitment&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="6850" y="4340" width="180" height="110" as="geometry"/></mxCell><mxCell id="167" value="&lt;b&gt;秘密监视（启用戴笠）&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;戴笠的情报网将对警卫、交通和党内通讯进行监控。这能提高行动把握，也会让政府越来越依赖阴影。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_secret_surveillance&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="7650" y="4340" width="180" height="110" as="geometry"/></mxCell><mxCell id="168" value="&lt;b&gt;寻求德国支持&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;该国策代表南京政府在当前路线下推进新的政治、军事或外交安排。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_seek_german_support&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="8050" y="4340" width="180" height="110" as="geometry"/></mxCell><mxCell id="169" value="&lt;b&gt;寻求日本支持&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;黄埔派需要外部承认，也需要打破外交孤立。东京不会免费提供支持，但它愿意认真观察南京的新秩序。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_seek_japanese_support&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="8450" y="4340" width="180" height="110" as="geometry"/></mxCell><mxCell id="170" value="&lt;b&gt;中央警卫团&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;中央警卫团将被重组为只听命于军官团核心的政治武装。这会提高行动成功率，也会让党内恐惧进一步扩散。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_central_guard_regiment&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="6450" y="4600" width="180" height="110" as="geometry"/></mxCell><mxCell id="171" value="&lt;b&gt;地下印刷厂&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;地下印刷所将为黄埔派制造传单、口号和伪造命令。纸张有时比子弹更适合摧毁一个政府的神经。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_underground_printing_house&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="6850" y="4470" width="180" height="110" as="geometry"/></mxCell><mxCell id="172" value="&lt;b&gt;地下通讯&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;秘密通信网将连接军营、警卫、蓝衣社行动组和南京城内的联络人。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_underground_communications&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="7450" y="4470" width="180" height="110" as="geometry"/></mxCell><mxCell id="173" value="&lt;b&gt;武装夺权的胜利&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;军官团已经掌握中央要地。武装夺权结束后，国家必须尽快恢复行政秩序，否则胜利本身会继续制造混乱。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_victory_of_armed_seizure&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="8250" y="4860" width="180" height="110" as="geometry"/></mxCell><mxCell id="174" value="&lt;b&gt;贺衷寒接管党中央&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;贺衷寒接管党中央后，黄埔军官、蓝衣社和军统系统将被重新编入一个统一的党国核心。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_he_zhonghan_takes_party_center&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="6450" y="4860" width="180" height="110" as="geometry"/></mxCell><mxCell id="175" value="&lt;b&gt;清除意见人士&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;该国策代表南京政府在当前路线下推进新的政治、军事或外交安排。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_eliminate_dissenters&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="6850" y="4600" width="180" height="110" as="geometry"/></mxCell><mxCell id="176" value="&lt;b&gt;建立黑名单&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;军统和蓝衣社将整理一份目标名单。名单越精确，行动越可能成功；名单越长，社会越难保持安静。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_build_blacklist&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="7850" y="4470" width="180" height="110" as="geometry"/></mxCell><mxCell id="177" value="&lt;b&gt;毛泽东的命运&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;新政权必须处理毛泽东留下的政治遗产。只有这一关被处理，黄埔线才会真正开始转入正面建设。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_fate_of_mao&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="7250" y="5120" width="180" height="110" as="geometry"/></mxCell><mxCell id="178" value="&lt;b&gt;来自日本的贺电&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;东京向南京新政权发来贺电。它不是友谊的证明，而是日本愿意承认中国政治变化已经成为新的事实。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_japanese_congratulations&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="6250" y="5380" width="180" height="110" as="geometry"/></mxCell><mxCell id="179" value="&lt;b&gt;中华人民复兴政府成立&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;中华人民复兴政府正式成立。黄埔线前期积累的混乱和阴影将被新的国家机器部分吸收。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_chinese_revival_government&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="7250" y="5250" width="180" height="110" as="geometry"/></mxCell><mxCell id="180" value="&lt;b&gt;建立皇家空军&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;该国策代表南京政府在当前路线下推进新的政治、军事或外交安排。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_establish_royal_air_force&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="9250" y="5380" width="180" height="110" as="geometry"/></mxCell><mxCell id="181" value="&lt;b&gt;中日共建的大东亚共荣圈&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;南京和东京将把反西方、反苏俄残余与大陆秩序问题包装成共同事业。合作会带来收益，也会制造新的民族主义裂痕。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_sino_japanese_co_prosperity_sphere&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="5850" y="5640" width="180" height="110" as="geometry"/></mxCell><mxCell id="182" value="&lt;b&gt;反日条约&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;即使新政权与日本短暂互相试探，东北、朝鲜和远东问题仍可能把双方推回战争。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_anti_japanese_treaty&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="6650" y="5640" width="180" height="110" as="geometry"/></mxCell><mxCell id="183" value="&lt;b&gt;提高门槛&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;该国策代表南京政府在当前路线下推进新的政治、军事或外交安排。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_raise_air_standards&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="8850" y="5640" width="180" height="110" as="geometry"/></mxCell><mxCell id="184" value="&lt;b&gt;降低门槛&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;该国策代表南京政府在当前路线下推进新的政治、军事或外交安排。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_lower_air_standards&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="9650" y="5640" width="180" height="110" as="geometry"/></mxCell><mxCell id="185" value="&lt;b&gt;蓝衣军扩权&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;该国策代表南京政府在当前路线下推进新的政治、军事或外交安排。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_expand_blue_shirts&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="7250" y="5640" width="180" height="110" as="geometry"/></mxCell><mxCell id="186" value="&lt;b&gt;亚洲的空中霸权&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;该国策代表南京政府在当前路线下推进新的政治、军事或外交安排。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_air_supremacy_over_asia&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="9250" y="5770" width="180" height="110" as="geometry"/></mxCell><mxCell id="187" value="&lt;b&gt;国家至上&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;该国策代表南京政府在当前路线下推进新的政治、军事或外交安排。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_state_supremacy&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="7250" y="5770" width="180" height="110" as="geometry"/></mxCell><mxCell id="188" value="&lt;b&gt;瓜分东北（像日本发送事件之类的）&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;东北不只是领土问题，也是中日两国能否共同管理大陆秩序的试金石。南京将向东京提出新的东北安排。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_partition_manchuria&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="5850" y="6030" width="180" height="110" as="geometry"/></mxCell><mxCell id="189" value="&lt;b&gt;中华民族主义&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;该国策代表南京政府在当前路线下推进新的政治、军事或外交安排。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_chinese_nationalism&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="7250" y="5900" width="180" height="110" as="geometry"/></mxCell><mxCell id="190" value="&lt;b&gt;寻求中德友好&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;该国策代表南京政府在当前路线下推进新的政治、军事或外交安排。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_seek_sino_german_friendship&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="7250" y="6290" width="180" height="110" as="geometry"/></mxCell><mxCell id="191" value="&lt;b&gt;陈绍宽下西洋&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;该国策代表南京政府在当前路线下推进新的政治、军事或外交安排。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_chen_shaokuan_oceanic_mission&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="7250" y="6420" width="180" height="110" as="geometry"/></mxCell><mxCell id="192" value="&lt;b&gt;东亚新秩序协定&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;如果日本接受南京的邀请，东亚将出现一个由中日共同塑造的新集团。它的口号是亚洲自决，它的现实则是权力再分配。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_east_asian_new_order_pact&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="5850" y="6160" width="180" height="110" as="geometry"/></mxCell><mxCell id="193" value="&lt;b&gt;对日作战&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;该国策代表南京政府在当前路线下推进新的政治、军事或外交安排。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_war_against_japan&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="6650" y="6160" width="180" height="110" as="geometry"/></mxCell><mxCell id="194" value="&lt;b&gt;剑指美洲&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;远洋舰队的任务不再只是护航。南京将把战争推向太平洋另一端，直接挑战美国与加拿大在美洲和太平洋上的安全体系。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_aim_at_america&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="7250" y="6550" width="180" height="110" as="geometry"/></mxCell><mxCell id="195" value="&lt;b&gt;南进&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;南洋的港口、橡胶、锡矿和航道决定中国能否成为真正的海权国家。南京将准备向东南亚投射力量。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_southern_advance&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="5650" y="6550" width="180" height="110" as="geometry"/></mxCell><mxCell id="196" value="&lt;b&gt;北上&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;北方的草原、铁路和西伯利亚边疆仍处于俄国崩溃后的真空中。南京将把边境安全推进到更远处。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_northern_advance&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="6050" y="6550" width="180" height="110" as="geometry"/></mxCell><mxCell id="197" value="&lt;b&gt;大亚洲共荣圈&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;战争、投资和政治承诺将被包装成新的亚洲共同繁荣。现实会更粗糙，但南京已经有能力把秩序推广到国境之外。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_greater_asian_co_prosperity_sphere&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="5850" y="6680" width="180" height="110" as="geometry"/></mxCell><mxCell id="198" value="&lt;b&gt;中华治下的新亚洲&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;中国将不再只是亚洲革命或民族主义的一支力量，而会成为新亚洲秩序的中心。周边国家必须重新理解南京的分量。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#666666&quot;&gt;70 days | UP_CHI_new_asia_under_china&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="6650" y="6680" width="180" height="110" as="geometry"/></mxCell><mxCell id="199" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#0000FF;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="2" target="3"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="200" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#0000FF;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent