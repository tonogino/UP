<mxfile host="app.diagrams.net" modified="2026-06-29T22:15:16.571Z" agent="HOI4 Modding Tools" version="1.0">
  <diagram id="focus-tree" name="UP_china_focus">
    <mxGraphModel dx="1000" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1920" pageHeight="1080">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="2" value="1933年的革命同盟 [title]&lt;br&gt;南京已经落入革命军手中，但革命同盟仍是由共产党人、地方农民武装、左翼残党和失意军官拼接起来的政权。 [desc]&lt;br&gt;70 [days]&lt;br&gt;UP_CHI_revolutionary_league_1933 [id]&lt;br&gt;GFX_goal_generic_propaganda [icon]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="2250" y="50" width="180" height="120" as="geometry"/></mxCell><mxCell id="3" value="南京革命政府 [title]&lt;br&gt;革命同盟必须证明自己不只是攻城军队，而是能治理城市、铁路、税收和粮食的国家核心。 [desc]&lt;br&gt;70 [days]&lt;br&gt;UP_CHI_nanjing_revolutionary_government [id]&lt;br&gt;GFX_goal_generic_political_pressure [icon]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="2250" y="200" width="180" height="120" as="geometry"/></mxCell><mxCell id="4" value="重庆问题 [title]&lt;br&gt;残余国民政府退入重庆，并与华南地方军阀结成同盟。南京若要统一中国，就必须决定如何处理西南的旧秩序。 [desc]&lt;br&gt;70 [days]&lt;br&gt;UP_CHI_the_chongqing_question [id]&lt;br&gt;GFX_goal_generic_demand_territory [icon]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="1450" y="350" width="180" height="120" as="geometry"/></mxCell><mxCell id="5" value="重建革命军 [title]&lt;br&gt;革命军由农民武装、旧军倒戈部队和青年军官组成。它打下了南京，但还不是一支真正统一的现代军队。 [desc]&lt;br&gt;70 [days]&lt;br&gt;UP_CHI_rebuild_the_revolutionary_army [id]&lt;br&gt;GFX_goal_generic_position_armies [icon]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="3050" y="350" width="180" height="120" as="geometry"/></mxCell><mxCell id="6" value="农村改革派 [title]&lt;br&gt;农村改革派认为革命的根基在土地、乡村组织和基层动员。只有先重塑农村，中国革命才不会成为又一个城市政权。 [desc]&lt;br&gt;70 [days]&lt;br&gt;UP_CHI_rural_reform_bloc [id]&lt;br&gt;GFX_goal_generic_soviet_construction [icon]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="850" y="650" width="180" height="120" as="geometry"/></mxCell><mxCell id="7" value="军国主义派 [title]&lt;br&gt;军国主义派认为分裂中国只能靠军队重新缝合。革命不能被乡村会议拖慢，必须建立纪律、参谋部和统一战争机器。 [desc]&lt;br&gt;70 [days]&lt;br&gt;UP_CHI_militarist_bloc [id]&lt;br&gt;GFX_goal_generic_major_war [icon]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="3650" y="650" width="180" height="120" as="geometry"/></mxCell><mxCell id="8" value="发动新土改 [title]&lt;br&gt;南京革命政府将把土地问题重新推向前台。农民获得动员，地主阶级则开始把革命视为生死威胁。 [desc]&lt;br&gt;70 [days]&lt;br&gt;UP_CHI_launch_new_land_reform [id]&lt;br&gt;GFX_goal_generic_communist_revolution [icon]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="850" y="800" width="180" height="120" as="geometry"/></mxCell><mxCell id="9" value="深入乡村 [title]&lt;br&gt;革命不能只停留在城市和军队。工作队、农会和基层干部将进入乡村，把南京的命令变成地方秩序。 [desc]&lt;br&gt;70 [days]&lt;br&gt;UP_CHI_deepen_the_countryside [id]&lt;br&gt;GFX_goal_generic_propaganda [icon]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="450" y="950" width="180" height="120" as="geometry"/></mxCell><mxCell id="10" value="建立人民公社 [title]&lt;br&gt;人民公社将生产、动员和基层治理结合起来。它们能创造新的建设速度，也会让社会承受更大压力。 [desc]&lt;br&gt;70 [days]&lt;br&gt;UP_CHI_establish_people_communes [id]&lt;br&gt;GFX_goal_generic_construct_civ_factory [icon]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="850" y="1100" width="180" height="120" as="geometry"/></mxCell><mxCell id="11" value="群众路线 [title]&lt;br&gt;群众路线把革命政府重新拉回基层。政策必须从群众中来，再回到群众中去。 [desc]&lt;br&gt;70 [days]&lt;br&gt;UP_CHI_mass_line [id]&lt;br&gt;GFX_goal_generic_national_unity [icon]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="1250" y="950" width="180" height="120" as="geometry"/></mxCell><mxCell id="12" value="整顿地方革命委员会 [title]&lt;br&gt;地方革命委员会曾经帮助南京夺取政权，如今却可能成为新的山头。中央必须重新握住基层权力。 [desc]&lt;br&gt;70 [days]&lt;br&gt;UP_CHI_rectify_local_revolutionary_committees [id]&lt;br&gt;GFX_goal_generic_political_pressure [icon]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="850" y="1400" width="180" height="120" as="geometry"/></mxCell><mxCell id="13" value="继续土地革命 [title]&lt;br&gt;土地革命不能在南京胜利后停下。农村社会仍然是中国革命最深的战场。 [desc]&lt;br&gt;70 [days]&lt;br&gt;UP_CHI_continue_land_revolution [id]&lt;br&gt;GFX_goal_generic_communist_revolution [icon]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="50" y="1550" width="180" height="120" as="geometry"/></mxCell><mxCell id="14" value="革命输出 [title]&lt;br&gt;南京将不再把革命局限在国境之内。亚洲各地的工人、农民和殖民地士兵都可能成为火种。 [desc]&lt;br&gt;70 [days]&lt;br&gt;UP_CHI_export_revolution [id]&lt;br&gt;GFX_goal_generic_intelligence_exchange [icon]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="50" y="1700" width="180" height="120" as="geometry"/></mxCell><mxCell id="15" value="亚洲革命中心 [title]&lt;br&gt;没有苏联的世界里，中国可以成为新的亚洲革命中心。 [desc]&lt;br&gt;70 [days]&lt;br&gt;UP_CHI_asian_revolution_center [id]&lt;br&gt;GFX_goal_generic_major_alliance [icon]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="50" y="1850" width="180" height="120" as="geometry"/></mxCell><mxCell id="16" value="世界革命的火种 [title]&lt;br&gt;革命政府将把战争、宣传和地下组织结合起来，让世界意识到东方的新中心已经出现。 [desc]&lt;br&gt;70 [days]&lt;br&gt;UP_CHI_spark_of_world_revolution [id]&lt;br&gt;GFX_goal_generic_demand_territory [icon]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="50" y="2000" width="180" height="120" as="geometry"/></mxCell><mxCell id="17" value="东方红照耀亚洲 [title]&lt;br&gt;南京不再只是中国的革命政府，而是亚洲红色运动的灯塔。 [desc]&lt;br&gt;70 [days]&lt;br&gt;UP_CHI_east_is_red_over_asia [id]&lt;br&gt;GFX_goal_generic_communist_revolution [icon]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="50" y="2150" width="180" height="120" as="geometry"/></mxCell><mxCell id="18" value="恢复国民经济 [title]&lt;br&gt;革命需要面包、煤炭、机器和铁路。南京必须从战争中恢复国民经济。 [desc]&lt;br&gt;70 [days]&lt;br&gt;UP_CHI_restore_national_economy [id]&lt;br&gt;GFX_goal_generic_construct_civ_factory [icon]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="1650" y="1550" width="180" height="120" as="geometry"/></mxCell><mxCell id="19" value="第一个五年计划 [title]&lt;br&gt;计划经济将把零散的工业、铁路和资源建设纳入统一节奏。 [desc]&lt;br&gt;70 [days]&lt;br&gt;UP_CHI_first_five_year_plan [id]&lt;br&gt;GFX_goal_generic_construct_civ_factory [icon]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="1650" y="1700" width="180" height="120" as="geometry"/></mxCell><mxCell id="20" value="农业合作化 [title]&lt;br&gt;农业合作化将提高粮食组织能力，也让农村生产与国家计划更紧密地连接。 [desc]&lt;br&gt;70 [days]&lt;br&gt;UP_CHI_agricultural_collectivization [id]&lt;br&gt;GFX_goal_generic_construct_infrastructure [icon]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="1650" y="1850" width="180" height="120" as="geometry"/></mxCell><mxCell id="21" value="人民工业化 [title]&lt;br&gt;没有工业，革命就无法保卫自己。人民工业化将培养工程师、技术员和新的科研体系。 [desc]&lt;br&gt;70 [days]&lt;br&gt;UP_CHI_peoples_industrialization [id]&lt;br&gt;GFX_goal_generic_scientific_exchange [icon]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="1650" y="2000" width="180" height="120" as="geometry"/></mxCell><mxCell id="22" value="革命现代国家 [title]&lt;br&gt;革命不能永远停留在动员阶段。中国式社会主义将把国家建设、工业生产和社会改造结合起来。 [desc]&lt;br&gt;70 [days]&lt;br&gt;UP_CHI_revolutionary_modern_state [id]&lt;br&gt;GFX_goal_generic_construct_mil_factory [icon]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="1650" y="2150" width="180" height="120" as="geometry"/></mxCell><mxCell id="23" value="黄埔军官团派 [title]&lt;br&gt;不少黄埔军官在蒋介石死后倒向南京。他们相信革命需要现代军官团，而不是无休止的群众动员。 [desc]&lt;br&gt;70 [days]&lt;br&gt;UP_CHI_whampoa_officer_corps [id]&lt;br&gt;GFX_goal_generic_army_doctrines [icon]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="3050" y="800" width="180" height="120" as="geometry"/></mxCell><mxCell id="24" value="吸收倒戈军校生 [title]&lt;br&gt;倒戈军校生带来了战术、纪律和旧国民革命军的经验，也带来了新的派系风险。 [desc]&lt;br&gt;70 [days]&lt;br&gt;UP_CHI_absorb_defected_cadets [id]&lt;br&gt;GFX_goal_generic_position_armies [icon]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="2850" y="950" width="180" height="120" as="geometry"/></mxCell><mxCell id="25" value="南京总参谋部 [title]&lt;br&gt;统一中国不能靠临时会议指挥。南京需要一个能规划多战线战争的总参谋部。 [desc]&lt;br&gt;70 [days]&lt;br&gt;UP_CHI_nanjing_general_staff [id]&lt;br&gt;GFX_goal_generic_army_artillery [icon]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="3250" y="950" width="180" height="120" as="geometry"/></mxCell><mxCell id="26" value="革命军事国家 [title]&lt;br&gt;军队将成为革命政权的脊梁。中国必须先被组织成军营，才能被组织成国家。 [desc]&lt;br&gt;70 [days]&lt;br&gt;UP_CHI_revolutionary_military_state [id]&lt;br&gt;GFX_goal_generic_major_war [icon]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="3050" y="1100" width="180" height="120" as="geometry"/></mxCell><mxCell id="27" value="继承孙中山派 [title]&lt;br&gt;这一路线主张南京革命政府才是国民革命的真正继承者。蒋介石死后，重庆只是旧官僚和地方军阀的避难所。 [desc]&lt;br&gt;70 [days]&lt;br&gt;UP_CHI_inherit_sun_yat_sen [id]&lt;br&gt;GFX_goal_generic_demand_territory [icon]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="4250" y="800" width="180" height="120" as="geometry"/></mxCell><mxCell id="28" value="第二次北伐 [title]&lt;br&gt;革命尚未完成，军阀仍在。南京将以新的旗帜继承北伐的未竟事业。 [desc]&lt;br&gt;70 [days]&lt;br&gt;UP_CHI_second_northern_expedition [id]&lt;br&gt;GFX_goal_generic_occupy_states_ongoing_war [icon]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="4050" y="950" width="180" height="120" as="geometry"/></mxCell><mxCell id="29" value="红旗下的三民主义 [title]&lt;br&gt;民族、民权、民生不必属于重庆。南京可以把孙中山的遗产重新解释为革命同盟的合法性。 [desc]&lt;br&gt;70 [days]&lt;br&gt;UP_CHI_three_principles_under_red_banner [id]&lt;br&gt;GFX_goal_generic_national_unity [icon]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="4450" y="950" width="180" height="120" as="geometry"/></mxCell><mxCell id="30" value="共和革命正统 [title]&lt;br&gt;南京宣布自己既是社会革命的中心，也是国民革命的继承者。重庆的旗帜已经褪色。 [desc]&lt;br&gt;70 [days]&lt;br&gt;UP_CHI_republican_revolutionary_claim [id]&lt;br&gt;GFX_goal_generic_forceful_treaty [icon]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="4250" y="1100" width="180" height="120" as="geometry"/></mxCell><mxCell id="31" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#0000FF;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="2" target="3"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="32" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#0000FF;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="3" target="4"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="33" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;htm