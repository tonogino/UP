<mxfile host="app.diagrams.net" modified="2026-07-02T17:24:53.684Z" agent="HOI4 Modding Tools" version="1.0">
  <diagram id="focus-tree" name="UP_japan_focus">
    <mxGraphModel dx="1000" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1920" pageHeight="1080">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="2" value="帝国抵达极限 [title]&lt;br&gt;日本赢得了远东，却发现胜利本身正在吞噬财政、军队和政治秩序。 [desc]&lt;br&gt;70 [days]&lt;br&gt;UP_JAP_empire_at_the_limit [id]&lt;br&gt;GFX_goal_generic_political_pressure [icon]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="2250" y="50" width="180" height="120" as="geometry"/></mxCell><mxCell id="3" value="哈尔滨冲击 [title]&lt;br&gt;满洲的挑战让东京意识到，所谓缓冲国已经不再安静，帝国必须决定如何处理这场羞辱。 [desc]&lt;br&gt;70 [days]&lt;br&gt;UP_JAP_harbin_shock [id]&lt;br&gt;GFX_goal_generic_demand_territory [icon]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="2250" y="200" width="180" height="120" as="geometry"/></mxCell><mxCell id="4" value="青年军官团政变 [title]&lt;br&gt;青年军官将财阀、政党和软弱内阁视为帝国病灶。他们准备以暴力拯救国家。 [desc]&lt;br&gt;70 [days]&lt;br&gt;UP_JAP_young_officers_coup [id]&lt;br&gt;GFX_goal_generic_dangerous_deal [icon]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="450" y="500" width="180" height="120" as="geometry"/></mxCell><mxCell id="5" value="昭和维新 [title]&lt;br&gt;维新派宣称一切行动都以天皇之名进行，旧体制的掣肘必须被清除。 [desc]&lt;br&gt;70 [days]&lt;br&gt;UP_JAP_showa_restoration [id]&lt;br&gt;GFX_goal_support_fascism [icon]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="450" y="650" width="180" height="120" as="geometry"/></mxCell><mxCell id="6" value="清洗财阀 [title]&lt;br&gt;财阀曾为扩张提供资金，如今却试图为风险踩刹车。维新派不会允许资本家决定帝国命运。 [desc]&lt;br&gt;70 [days]&lt;br&gt;UP_JAP_purge_the_zaibatsu [id]&lt;br&gt;GFX_goal_generic_political_pressure [icon]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="50" y="800" width="180" height="120" as="geometry"/></mxCell><mxCell id="7" value="军事独裁 [title]&lt;br&gt;帝国将由军队的纪律和命令重塑，议会、财阀与文官内阁都必须退后。 [desc]&lt;br&gt;70 [days]&lt;br&gt;UP_JAP_military_dictatorship [id]&lt;br&gt;GFX_goal_generic_position_armies [icon]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="450" y="800" width="180" height="120" as="geometry"/></mxCell><mxCell id="8" value="天皇亲政名义 [title]&lt;br&gt;实际权力落入军方手中，但所有命令都将被包装为天皇意志。 [desc]&lt;br&gt;70 [days]&lt;br&gt;UP_JAP_rule_in_the_emperors_name [id]&lt;br&gt;GFX_goal_generic_national_unity [icon]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="850" y="800" width="180" height="120" as="geometry"/></mxCell><mxCell id="9" value="重新征服满洲 [title]&lt;br&gt;满洲若不能自愿听命，就必须重新学会沉默。关东军将恢复帝国威信。 [desc]&lt;br&gt;70 [days]&lt;br&gt;UP_JAP_reconquer_manchuria [id]&lt;br&gt;GFX_goal_generic_attack_allies [icon]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="450" y="950" width="180" height="120" as="geometry"/></mxCell><mxCell id="10" value="对华圣战 [title]&lt;br&gt;南京的革命政权被维新派视为亚洲秩序的最大威胁。帝国必须先下手。 [desc]&lt;br&gt;70 [days]&lt;br&gt;UP_JAP_holy_war_against_china [id]&lt;br&gt;GFX_goal_generic_major_war [icon]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="250" y="1100" width="180" height="120" as="geometry"/></mxCell><mxCell id="11" value="北进西伯利亚 [title]&lt;br&gt;俄国碎裂后的远东真空不能留给别人。西伯利亚将成为帝国北方战略的下一步。 [desc]&lt;br&gt;70 [days]&lt;br&gt;UP_JAP_strike_siberia [id]&lt;br&gt;GFX_goal_generic_demand_territory [icon]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="650" y="1100" width="180" height="120" as="geometry"/></mxCell><mxCell id="12" value="旧体制路线 [title]&lt;br&gt;政党、财阀、陆军、海军和宫廷仍能维持脆弱平衡。帝国不需要政变，只需要重新选择方向。 [desc]&lt;br&gt;70 [days]&lt;br&gt;UP_JAP_preserve_the_old_system [id]&lt;br&gt;GFX_goal_generic_neutrality_focus [icon]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="3450" y="500" width="180" height="120" as="geometry"/></mxCell><mxCell id="13" value="陆军北进派 [title]&lt;br&gt;陆军认为帝国命运在大陆。满洲、远东和中国革命必须被军事力量压住。 [desc]&lt;br&gt;70 [days]&lt;br&gt;UP_JAP_army_northern_faction [id]&lt;br&gt;GFX_goal_generic_position_armies [icon]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="2250" y="650" width="180" height="120" as="geometry"/></mxCell><mxCell id="14" value="控制满洲 [title]&lt;br&gt;满洲是帝国大陆政策的锁钥。东京不能容忍它在夹缝中自行其是。 [desc]&lt;br&gt;70 [days]&lt;br&gt;UP_JAP_control_manchuria [id]&lt;br&gt;GFX_goal_generic_demand_territory [icon]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="2050" y="800" width="180" height="120" as="geometry"/></mxCell><mxCell id="15" value="远东战争 [title]&lt;br&gt;远东不是帝国的边缘，而是北进派眼中的新边界。 [desc]&lt;br&gt;70 [days]&lt;br&gt;UP_JAP_far_eastern_war [id]&lt;br&gt;GFX_goal_generic_major_war [icon]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="2050" y="950" width="180" height="120" as="geometry"/></mxCell><mxCell id="16" value="打击中国革命 [title]&lt;br&gt;南京革命同盟若继续成长，日本在大陆的所有投入都会被红色浪潮吞没。 [desc]&lt;br&gt;70 [days]&lt;br&gt;UP_JAP_strike_chinese_revolution [id]&lt;br&gt;GFX_goal_generic_attack_allies [icon]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="2050" y="1100" width="180" height="120" as="geometry"/></mxCell><mxCell id="17" value="海军南进派 [title]&lt;br&gt;海军拒绝继续把燃料和钢铁丢进大陆泥潭。帝国真正的资源在南方海域。 [desc]&lt;br&gt;70 [days]&lt;br&gt;UP_JAP_navy_southern_faction [id]&lt;br&gt;GFX_goal_generic_navy_doctrines_tactics [icon]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="3450" y="650" width="180" height="120" as="geometry"/></mxCell><mxCell id="18" value="放弃大陆泥潭 [title]&lt;br&gt;日本不必亲自背负每一寸远东土地。收缩大陆承诺，才能准备海洋战争。 [desc]&lt;br&gt;70 [days]&lt;br&gt;UP_JAP_abandon_the_continental_mire [id]&lt;br&gt;GFX_goal_generic_defence [icon]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="3450" y="800" width="180" height="120" as="geometry"/></mxCell><mxCell id="19" value="南洋资源圈 [title]&lt;br&gt;石油、橡胶、锡矿、港口和航线将决定帝国能否继续扩张。 [desc]&lt;br&gt;70 [days]&lt;br&gt;UP_JAP_southern_resource_sphere [id]&lt;br&gt;GFX_goal_generic_positive_trade_relations [icon]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="3450" y="950" width="180" height="120" as="geometry"/></mxCell><mxCell id="20" value="太平洋舰队扩张 [title]&lt;br&gt;若帝国转向南方，舰队就必须成为国家的第一工具。 [desc]&lt;br&gt;70 [days]&lt;br&gt;UP_JAP_expand_the_pacific_fleet [id]&lt;br&gt;GFX_goal_generic_construct_naval_dockyard [icon]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="3450" y="1100" width="180" height="120" as="geometry"/></mxCell><mxCell id="21" value="财阀文官派 [title]&lt;br&gt;财阀和文官并不反对帝国，只反对把帝国赌在失控的军官和无底洞般的大陆战线上。 [desc]&lt;br&gt;70 [days]&lt;br&gt;UP_JAP_zaibatsu_civilian_faction [id]&lt;br&gt;GFX_goal_generic_construct_civ_factory [icon]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="4650" y="650" width="180" height="120" as="geometry"/></mxCell><mxCell id="22" value="稳定帝国 [title]&lt;br&gt;财政、殖民地、贸易和军队都需要重新排队。帝国必须先停止流血，才能继续统治。 [desc]&lt;br&gt;70 [days]&lt;br&gt;UP_JAP_stabilize_the_empire [id]&lt;br&gt;GFX_goal_generic_national_unity [icon]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="4650" y="800" width="180" height="120" as="geometry"/></mxCell><mxCell id="23" value="与英美妥协 [title]&lt;br&gt;与其同时挑战所有海权，不如用贸易和外交争取时间。 [desc]&lt;br&gt;70 [days]&lt;br&gt;UP_JAP_compromise_with_anglo_america [id]&lt;br&gt;GFX_goal_generic_improve_relations [icon]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="4650" y="950" width="180" height="120" as="geometry"/></mxCell><mxCell id="24" value="经济殖民体系 [title]&lt;br&gt;控制不一定总靠军靴。资本、港口、贷款、顾问和贸易网络也能组成帝国。 [desc]&lt;br&gt;70 [days]&lt;br&gt;UP_JAP_economic_colonial_system [id]&lt;br&gt;GFX_goal_generic_trade [icon]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="4650" y="1100" width="180" height="120" as="geometry"/></mxCell><mxCell id="25" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#0000FF;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="2" target="3"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="26" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#0000FF;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="3" target="4"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="27" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#0000FF;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="4" target="5"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="28" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#0000FF;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="5" target="6"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="29" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#0000FF;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="5" target="7"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="30" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#0000FF;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="5" target="8"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="31" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#0000FF;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="6" target="9"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="32" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#0000FF;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="7" target="9"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="33" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#0000FF;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="8" target="9"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="34" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#0000FF;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="9" target="10"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="35" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#0000FF;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="9" target="11"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="36" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#